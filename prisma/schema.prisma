generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  name     String
  password String

  accounts Account[]

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id       String        @id @default(uuid())
  status   AccountStatus @default(ACTIVE)
  currency String        @default("INR")
  balance  Float         @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  outgoingTransactions Transaction[] @relation("SenderAccount")
  incomingTransactions Transaction[] @relation("ReceiverAccount")

  ledgers Ledger[]

  createAt     DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

model Transaction {
  id String @id @default(uuid())

  fromAccountId String
  fromAccount   Account @relation("SenderAccount", fields: [fromAccountId], references: [id])

  toAccountId String
  toAccount   Account @relation("ReceiverAccount", fields: [toAccountId], references: [id])

  status         TransactionStatus @default(PENDING)
  amount         Float
  idempotencyKey String            @unique

  ledgers Ledger[]

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  account   Account? @relation(fields: [accountId], references: [id])
  accountId String?
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

model Ledger {
  id String @id @default(uuid())

  amount Float

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  type LedgerType

  createdAt DateTime @default(now())
}

enum LedgerType {
  CREDIT
  DEBIT
}
